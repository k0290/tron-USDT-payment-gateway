# Tron Payment SDK — root .env template
# Usage: cp .env.example .env  then fill values (see README.md)
# Never commit .env to git.

# ============ Required (payments) ============

# From: python key_management/derive_xpub.py  (path m/44'/195'/0')
ACCOUNT_XPUB=

# Network pair — use ONE block (Nile testnet OR mainnet), do not mix.

# --- Nile testnet ---
# TRONGRID_API_URL=https://nile.trongrid.io
# USDT_CONTRACT_ADDRESS=TXYZopYRdj2D9XRtbG411XZZ3kM5VkAeBf

# --- Mainnet ---
TRONGRID_API_URL=https://api.trongrid.io
USDT_CONTRACT_ADDRESS=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# Optional: https://www.trongrid.io/
TRONGRID_API_KEY=

# Invoice payment window in seconds; pending orders expire after this (default 3600 = 1 hour)
EXPIRE_TIME_WINDOW=3600

# ============ Optional (sweep only) ============

# From: python key_management/derive_address.py  or your own treasury address
COLD_WALLET_ADDRESS=

# Signing service (see signing_server/.env.example)
SIGNING_SERVICE_URL=http://127.0.0.1:9090

# TRX operations wallet: freeze/delegate energy + activate deposit addresses (hex, no 0x)
TRX_SOURCE_PRIVATE_KEY=

# Minimum USDT balance on a deposit address before sweep (default 10.0)
SWEEP_MIN_AMOUNT_USDT=10.0

# ============ Energy mode (sweep) ============

# How to fund the USDT transfer fee: 'delegate' (freeze/delegate from ops wallet, default)
# or 'rent' (rent one-shot energy from tronenergy.market right before each sweep)
ENERGY_MODE=delegate

# ---- tronenergy.market rental (used when ENERGY_MODE=rent) ----
TRONENERGY_API_SERVER=https://api.tronenergy.market
TRONENERGY_SERVER_ADDRESS=TEMkRxLtCCdL4BCwbPXbbNWe4a9gtJ7kq7

# Payment option A (recommended): prepay credit + API key (no per-order signing).
# API key must match the payer address.
TRONENERGY_API_KEY=
TRONENERGY_PAYER_ADDRESS=
# Payment option B: leave API key blank to pay each order by signing a TRX transfer
# with TRX_SOURCE_PRIVATE_KEY above.

# Energy units per sweep (one USDT transfer to an existing holder ≈ 65000)
RENT_ENERGY_AMOUNT=65000
# Rental duration in seconds (10 min is plenty to fire the sweep)
RENT_DURATION_SECONDS=600
# Bid in SUN per energy per day. Higher fills faster but costs more (~35-50 typical)
RENT_PRICE_SUN=50
# Allow multiple lenders to fill one order
RENT_PARTFILL=true
# Max seconds to wait for rented energy to arrive before giving up
RENT_WAIT_TIMEOUT=60
# If renting fails, fall back to freeze/delegate (needs TRX_SOURCE_PRIVATE_KEY)
RENT_FALLBACK_TO_DELEGATE=true
